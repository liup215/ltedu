{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run API",
            "type": "shell",
            "command": "go run cmd/main.go",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "group": "ltedu",
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$go"]
        },
        {
            "label": "Run Web",
            "type": "shell",
            "command": "npm install && npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/web"
            },
            "presentation": {
                "group": "ltedu",
                "reveal": "always",
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "typescript",
                "pattern": {
                    "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
                    "file": 1,
                    "location": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "custom-pattern-to-match-nothing-or-fix-later-usually-vite-prints-ready"
                }
            }
        },
        {
            "label": "Run All",
            "dependsOn": ["Run API", "Run Web"],
            "problemMatcher": []
        }
    ]
}