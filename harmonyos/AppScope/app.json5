{
  "app": {
    "bundleName": "com.ltedu.app",
    "vendor": "ltedu",
    "versionCode": 1000000,
    "versionName": "1.0.0",
    "icon": "$media:app_icon",
    "label": "$string:app_name",
    "description": "$string:app_desc",
    "minAPIVersion": 12,
    "targetAPIVersion": 12,
    "apiReleaseType": "Release",
    "distributionFilter": {
      "screenShape": {
        "policy": "exclude",
        "value": ["circle"]
      }
    }
  }
}
